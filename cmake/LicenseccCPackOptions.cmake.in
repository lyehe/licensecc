set(LCC_CPACK_PACKAGE_PROFILE "@LCC_PACKAGE_PROFILE@")
set(LCC_CPACK_PROJECT_NAME "@LCC_PROJECT_NAME@")
set(LCC_CPACK_SYSTEM_NAME "@CMAKE_SYSTEM_NAME@")
set(LCC_CPACK_ABI_TAG "@LCC_PACKAGE_ABI_TAG@")
set(LCC_CPACK_CONFIG_ID "@LCC_PACKAGE_BUILD_CONFIG@")
if(NOT DEFINED LCC_ALLOW_DEFAULT_PROJECT_FOR_RELEASE)
	set(LCC_ALLOW_DEFAULT_PROJECT_FOR_RELEASE "@LCC_ALLOW_DEFAULT_PROJECT_FOR_RELEASE@")
endif()
if(NOT DEFINED LCC_ALLOW_RELEASE_PROJECT_KEYGEN)
	set(LCC_ALLOW_RELEASE_PROJECT_KEYGEN "@LCC_ALLOW_RELEASE_PROJECT_KEYGEN@")
endif()
if(NOT DEFINED LCC_MIN_RELEASE_PUBLIC_KEY_DER_LEN)
	set(LCC_MIN_RELEASE_PUBLIC_KEY_DER_LEN "@LCC_MIN_RELEASE_PUBLIC_KEY_DER_LEN@")
endif()
if(NOT DEFINED LCC_MIN_RELEASE_PUBLIC_KEY_BITS)
	set(LCC_MIN_RELEASE_PUBLIC_KEY_BITS "@LCC_MIN_RELEASE_PUBLIC_KEY_BITS@")
endif()
set(LCC_CPACK_FORBIDDEN_RELEASE_PROJECT_NAMES "@LCC_FORBIDDEN_RELEASE_PROJECT_NAMES@")
set(LCC_CPACK_PROJECT_PUBLIC_KEY "@LCC_PROJECT_PUBLIC_KEY@")
set(LCC_CPACK_PROJECT_PRIVATE_KEY "@LCC_PROJECT_PRIVATE_KEY@")

if(DEFINED CPACK_SOURCE_PACKAGE_FILE_NAME)
	set(CPACK_PACKAGE_FILE_NAME "${CPACK_PACKAGE_NAME}-${CPACK_PACKAGE_VERSION}-source")
	set(CPACK_SOURCE_PACKAGE_FILE_NAME "${CPACK_PACKAGE_FILE_NAME}")
elseif(DEFINED CPACK_BUILD_CONFIG AND NOT "${CPACK_BUILD_CONFIG}" STREQUAL "")
	set(LCC_CPACK_CONFIG_ID "${CPACK_BUILD_CONFIG}")

	set(CPACK_PACKAGE_FILE_NAME
		"${CPACK_PACKAGE_NAME}-${CPACK_PACKAGE_VERSION}-${LCC_CPACK_PACKAGE_PROFILE}-${LCC_CPACK_PROJECT_NAME}-${LCC_CPACK_CONFIG_ID}-${LCC_CPACK_ABI_TAG}-${LCC_CPACK_SYSTEM_NAME}")
else()
	set(CPACK_PACKAGE_FILE_NAME
		"${CPACK_PACKAGE_NAME}-${CPACK_PACKAGE_VERSION}-${LCC_CPACK_PACKAGE_PROFILE}-${LCC_CPACK_PROJECT_NAME}-${LCC_CPACK_CONFIG_ID}-${LCC_CPACK_ABI_TAG}-${LCC_CPACK_SYSTEM_NAME}")
endif()

if(NOT DEFINED CPACK_SOURCE_PACKAGE_FILE_NAME)
	set(LCC_CONFIG_NAME "${LCC_CPACK_CONFIG_ID}")
	set(LCC_PROJECT_NAME "${LCC_CPACK_PROJECT_NAME}")
	set(LCC_FORBIDDEN_RELEASE_PROJECT_NAMES "${LCC_CPACK_FORBIDDEN_RELEASE_PROJECT_NAMES}")
	set(LCC_PROJECT_PUBLIC_KEY "${LCC_CPACK_PROJECT_PUBLIC_KEY}")
	set(LCC_PROJECT_PRIVATE_KEY "${LCC_CPACK_PROJECT_PRIVATE_KEY}")
	set(_lccgen_path_file "@CMAKE_BINARY_DIR@/LicenseccLccgenPath-${LCC_CPACK_CONFIG_ID}.cmake")
	if(EXISTS "${_lccgen_path_file}")
		include("${_lccgen_path_file}")
	endif()
	set(LCC_ENFORCE_RELEASE_ARTIFACT_POLICY ON)
	include("@CMAKE_CURRENT_SOURCE_DIR@/cmake/CheckReleaseProject.cmake")
endif()
