      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/ci-windows-msvc-debug-dynamic",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_DISABLE_FIND_PACKAGE_OpenSSL": "TRUE",
        "CMAKE_INSTALL_PREFIX": "C:/licensecc",
        "LCC_PROJECT_NAME": "test",
        "STATIC_RUNTIME": "FALSE"
      }
    },
    {
      "name": "ci-windows-msvc-debug-static",
