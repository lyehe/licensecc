        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/dev-release",
        "LCC_PROJECT_NAME": "test"
      }
    },
    {
      "name": "ci-linux-debug",
      "displayName": "CI Linux Debug",
